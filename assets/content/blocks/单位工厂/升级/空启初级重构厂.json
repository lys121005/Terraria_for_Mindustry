{
    // 建筑类型：重构工厂（对应原版Reconstructor）
    "type": "Reconstructor",
    // 建筑名称
    "name": "空启初级重构厂",
    // 建筑描述
    "description": "将T1空军单位升级为T2",
    // 建筑生命值
    "health": 500,
    // 建筑自身建造耗时（单位：tick，游戏内1秒=60tick）
