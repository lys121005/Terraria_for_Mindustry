    // 单位升级耗时（单位：tick）
    "constructTime": 900,
    // 解锁该建筑所需的资源（研究完成后建造的前置资源）
    "requirements": [
        "腥红锭/25",
        "魔锭/25"
    ],
    // 建筑分类：单位类（对应游戏内单位建造/升级分类）
